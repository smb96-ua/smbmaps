<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/androidX"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/background_dark"
    android:padding="16dp">

    <!-- Left Panel - PIP Section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/panel_background"
        android:padding="16dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Picture in Picture"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- No app selected state -->
        <TextView
            android:id="@+id/textNoPip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select an app from the right panel to display in PIP mode"
            android:textColor="@color/text_secondary"
            android:textAlignment="center"
            android:layout_gravity="center"
            android:layout_marginTop="100dp" />

        <!-- Selected app container -->
        <LinearLayout
            android:id="@+id/pipContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imageSelectedApp"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/app_icon_background" />

            <TextView
                android:id="@+id/textSelectedApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/buttonLaunchApp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Launch"
                    android:layout_marginEnd="8dp"
                    style="@style/CarPlayButton" />

                <Button
                    android:id="@+id/buttonPipMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PIP Mode"
                    style="@style/CarPlayButton" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Right Panel - Apps Grid -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/panel_background"
        android:padding="16dp"
        android:layout_marginStart="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Applications"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewApps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical" />

    </LinearLayout>

</LinearLayout>